# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file -- it's already in .gitignore.

# Get a free RPC URL from https://www.alchemy.com or https://infura.io
# (sign up, create an app, select "Sepolia" testnet)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key_here

# A throwaway testnet-only wallet. Create a NEW wallet just for this
# (e.g. a new account in MetaMask) -- never use a wallet that holds
# real funds. Export its private key from MetaMask: Account Details ->
# Show Private Key.
PRIVATE_KEY=your_testnet_only_private_key_here

# The public address of that same wallet
WALLET_ADDRESS=0xYourTestnetWalletAddress

# A second address to send the test transaction to. Can be a second
# testnet account you control, or any address -- it's only ever a
# few cents of free testnet ETH.
RECIPIENT_ADDRESS=0xAnyTestnetAddress
